# Jarvis environment variables
# Copy to .env and fill in your keys
# IMPORTANT: .env must be UTF-8 sin BOM (PS 5.1 anade BOM con Set-Content -Encoding utf8)
# Usar: [System.IO.File]::WriteAllText($path, $content, [System.Text.UTF8Encoding]::new($false))

# Google AI Studio - https://aistudio.google.com/app/apikey
# Gemini Live requires beta access in some regions; verify in Fase 0
GEMINI_API_KEY=your_google_ai_studio_key_here

# Anthropic - https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# OpenAI - GPT 5.5 para codigo y modo agentico
OPENAI_API_KEY=your_openai_key_here
JARVIS_AGENTIC_CODE_MODEL=gpt-5.5
JARVIS_OPENAI_TIMEOUT_S=45

# Jarvis runtime mode
# dev  = dry-run, anuncia acciones pero NO las ejecuta
# prod = ejecuta acciones reales
JARVIS_MODE=dev

# Voice config
# Voices: Aoede, Charon, Fenrir, Kore, Puck, Leda, Orus, Zephyr
GEMINI_VOICE=Charon
# Lista ordenada de voces fallback si la principal no esta disponible
GEMINI_VOICE_FALLBACKS=Orus,Puck,Fenrir

# Language for system prompt
JARVIS_LANG=es-419

# Budgets. period=session|daily|weekly. daily/weekly use data/usage.db history.
JARVIS_BUDGET_GEMINI_USD=2.00
JARVIS_BUDGET_CLAUDE_USD=1.00
JARVIS_BUDGET_PERIOD=session
JARVIS_BUDGET_HARD_STOP=true

# Obsidian memory
JARVIS_OBSIDIAN_VAULT=H:\Obsidian ClaudeCode\Obsidian Claude Code
JARVIS_OBSIDIAN_MEMORY_FOLDER=Jarvis Memory
JARVIS_OBSIDIAN_READ_ALL=true
JARVIS_OBSIDIAN_MCP_ALLOW_DELETE=false

# Semantic memory (multi-source local RAG)
# Indexa fuentes locales seguras: Obsidian, memorias Claude/Codex, resumenes
# de historiales JSONL y docs Markdown/README del workspace. Los JSONL brutos
# se resumen/redactan antes de entrar al indice.
JARVIS_SEMANTIC_MEMORY_ENABLED=true
JARVIS_SEMANTIC_INDEX_DIR=data\semantic_memory
JARVIS_SEMANTIC_SOURCES=obsidian,claude_memory,codex_memory,agent_history_summaries,project_docs
JARVIS_SEMANTIC_MAX_RESULTS=8
JARVIS_SEMANTIC_MIN_SCORE=0.32
JARVIS_SEMANTIC_HISTORY_MAX_FILES=120
JARVIS_WORKSPACE_ROOT=C:\Users\Isaac\Desktop\PROYECTOS
JARVIS_CLAUDE_MEMORY_DIR=C:\Users\Isaac\.claude\projects\c--Users-Isaac-Desktop-PROYECTOS\memory
JARVIS_CLAUDE_HISTORY_DIR=C:\Users\Isaac\.claude\projects\c--Users-Isaac-Desktop-PROYECTOS
JARVIS_CODEX_MEMORY_DIR=C:\Users\Isaac\.codex\memories
JARVIS_CODEX_SESSIONS_DIR=C:\Users\Isaac\.codex\sessions

# Safe file organizer
# Lista de carpetas que Jarvis puede inspeccionar y organizar. Separar con ;
# en Windows. No uses C:\ completo, Windows, Program Files, ProgramData ni AppData.
# apply requiere aprobacion HITL y en JARVIS_ORGANIZER_MODE=dev hace dry-run.
JARVIS_ORGANIZER_ROOTS=C:\Users\Isaac\Desktop;C:\Users\Isaac\Downloads;C:\Users\Isaac\Documents;C:\Users\Isaac\Pictures;C:\Users\Isaac\Videos;C:\Users\Isaac\Music;C:\Users\Isaac\Desktop\PROYECTOS
# dev = preview/plan solamente; prod = permite mover archivos con aprobacion HITL.
# Esto afecta solo al organizador; si se omite, hereda JARVIS_MODE.
JARVIS_ORGANIZER_MODE=dev

# Skills runtime
# Importa skills documentadas tipo Codex desde carpetas que contienen */SKILL.md.
# Separar multiples roots con ; en Windows.
JARVIS_SKILL_IMPORT_DIRS=C:\Users\Isaac\.codex\skills

# Spotify control (crear app en https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback
# Cache OAuth local para que Jarvis corra headless despues del primer login
JARVIS_SPOTIFY_CACHE_PATH=data\spotify\.cache
# Market para busquedas; US es estable. Cambiar a CR si queres resultados locales.
JARVIS_SPOTIFY_MARKET=US

# Chrome reader
# Si lanzas Chrome con --remote-debugging-port=9222, Jarvis puede leer DOM completo.
# Sin eso, usa UI Automation de Windows y fallback por URL publica.
JARVIS_CHROME_DEBUG_PORT=9222

# Study Mode
# Captura evidencia de Chrome en background cuando Study Mode esta activo.
JARVIS_STUDY_CAPTURE_INTERVAL_S=45
JARVIS_STUDY_MAX_CHARS=9000

# OBS Memory
# Controla OBS por WebSocket, procesa grabaciones y guarda memoria episodica en Obsidian.
# OBS 28+ trae WebSocket integrado. En OBS: Tools -> WebSocket Server Settings.
JARVIS_OBS_MEMORY_ENABLED=false
JARVIS_OBS_RECORDING_DIR=C:\Users\Isaac\Videos
JARVIS_OBS_WEBSOCKET_HOST=127.0.0.1
JARVIS_OBS_WEBSOCKET_PORT=4455
JARVIS_OBS_WEBSOCKET_PASSWORD=
JARVIS_OBS_AUTO_START=true
JARVIS_OBS_EXE=C:\Program Files\obs-studio\bin\64bit\obs64.exe
JARVIS_OBS_STARTUP_TIMEOUT_S=20
# keep_video conserva el original; delete_video_after_success borra solo tras escribir la nota.
JARVIS_OBS_RETENTION=keep_video
JARVIS_OBS_ALLOW_EXTERNAL_VIDEO_PATHS=false
JARVIS_OBS_OUTPUT_FOLDER=obs_sessions
JARVIS_OBS_ANALYSIS_MODE=course
JARVIS_OBS_COURSE_CHUNK_SEC=300
JARVIS_OBS_COURSE_KEYFRAMES_PER_CHUNK=6
JARVIS_OBS_WHISPER_MODEL=small
JARVIS_OBS_WHISPER_DEVICE=cpu
JARVIS_OBS_WHISPER_COMPUTE_TYPE=int8
JARVIS_OBS_KEYFRAMES=8
JARVIS_OBS_MAX_TRANSCRIPT_CHARS=30000
JARVIS_OBS_PROCESS_BACKGROUND=true
# Opcional: evita depender de que Windows refresque PATH despues de winget.
JARVIS_FFMPEG_DIR=

# UI surface.
#   tk   = classic Tkinter overlay (legacy, soporta JARVIS_HIDE_FROM_CAPTURE)
#   web  = SSE bridge headless + React UI en Tauri (produccion)
# El ejecutable JARVIS Desktop (jarvis-desktop.exe) establece JARVIS_UI=web
# automaticamente. Solo cambia esto aqui si corres jarvis.py directamente.
JARVIS_UI=tk
JARVIS_WEB_UI_HOST=127.0.0.1
JARVIS_WEB_UI_PORT=8765
JARVIS_WEB_UI_OPEN_BROWSER=true
# UI audio animation cap. Keeps visuals smooth without adding latency.
JARVIS_WEB_UI_AUDIO_FPS=30

# Supervised watchdog (anti-zombie).
# Cuando se activa (=1), el backend Python se cierra automaticamente si no
# hay clientes SSE conectados durante JARVIS_WEB_WATCHDOG_GRACE_S segundos.
# jarvis-desktop.exe activa esto automaticamente; NO lo pongas en .env salvo
# para pruebas manuales del watchdog.
JARVIS_SUPERVISED=0
JARVIS_WEB_WATCHDOG_GRACE_S=60

# Overlay capture invisibility. Only the classic Tkinter UI can be hidden from
# capture; browser UI remains visible by design.
JARVIS_HIDE_FROM_CAPTURE=false
# Screenshots saved in data/screenshots are deleted after this many hours.
# Use 0 to delete previous screenshots before each new capture.
JARVIS_SCREENSHOT_RETENTION_HOURS=24

# === Logging ===
# Niveles validos: DEBUG | INFO | WARNING | ERROR | CRITICAL
JARVIS_LOG_LEVEL=INFO
# Rotacion y retencion del archivo data/jarvis.log (sintaxis loguru)
JARVIS_LOG_ROTATION=10 MB
JARVIS_LOG_RETENTION=7 days
# Journal JSONL estructurado para bug hunt: data/error_journal.jsonl.
JARVIS_ERROR_JOURNAL=true
# Opcional: path absoluto/relativo para mover el journal estructurado.
JARVIS_ERROR_JOURNAL_PATH=

# === Healthcheck de arranque ===
# Segundos maximos para verificar mic/speaker/Gemini/vault al iniciar
JARVIS_HEALTHCHECK_TIMEOUT=5.0
# true = aborta si falla. false = arranca degraded.
JARVIS_HEALTHCHECK_STRICT=true

# === Reconexion Gemini ===
# Backoff exponencial (segundos base) si la WS cae mid-sesion
JARVIS_RECONNECT_BACKOFF_BASE=1.0
JARVIS_RECONNECT_BACKOFF_MAX=16.0

# === Context window compression (sesiones largas) ===
# Comprime turnos viejos con ventana deslizante cuando el contexto se acerca al
# limite, para que sesiones LARGAS no se saturen (sin esto: respuestas lentas y
# "empieza de cero" al truncarse). Recomendado dejar en true.
JARVIS_CONTEXT_COMPRESSION=true
# Cuando el contexto supera estos tokens, dispara la compresion.
JARVIS_CONTEXT_TRIGGER_TOKENS=25600
# A cuantos tokens baja al comprimir (ventana retenida).
JARVIS_CONTEXT_TARGET_TOKENS=12800

# === Barge-in en modo escucha libre (LIBRE) por wake-word ===
# Permite cortar a Jarvis mientras habla, sin teclado: deci "Hey JARVIS".
# Usa wake-word (openWakeWord) en vez de energia/VAD porque el eco de la propia
# voz de Jarvis por los parlantes tiene la misma energia que tu voz (no se puede
# separar por umbral), pero el eco NUNCA dice la frase clave -> cero falsos
# positivos. Funciona igual en parlantes y auriculares.
# Requiere: pip install openwakeword  (y descargar modelos 1 vez, ver README).
# Si la dependencia falta, el barge-in se desactiva con gracia.
JARVIS_LIBRE_BARGE_IN=true
# Modelo de wake-word pre-entrenado de openWakeWord (hey_jarvis, alexa, etc).
JARVIS_WAKEWORD_MODEL=hey_jarvis
# Umbral de deteccion 0-1. Subilo (0.6-0.7) si se dispara solo; bajalo (0.3-0.4)
# si te cuesta que te escuche al decir "Hey JARVIS".
JARVIS_WAKEWORD_THRESHOLD=0.5
# AEC (cancelacion de eco): limpia la voz de Jarvis del mic ANTES del wake-word,
# para que funcione en PARLANTES (sin esto el eco enmascara tu voz). El log
# muestra "AEC ERLE peak=XXdB" (dB de eco cancelado; >10 es bueno).
JARVIS_AEC=true
# Particiones del filtro: cubren block*partitions/16000 seg de eco (8=256ms).
# Subi a 12-16 si tu sala tiene mucho eco/reverb (mas CPU).
JARVIS_AEC_PARTITIONS=8
# Paso de adaptacion del filtro (0.1-0.5). Mas alto converge rapido pero menos
# estable; mas bajo es estable pero lento.
JARVIS_AEC_MU=0.3

# --- Fase 1: Continuidad entre sesiones ---
# Master switch de toda la feature (journal + síntesis + recall).
JARVIS_SESSION_JOURNAL_ENABLED=true
# Mínimo de turnos para generar nota de sesión (evita ruido en sesiones triviales).
JARVIS_SESSION_MIN_TURNS=3
# Cap de caracteres del bloque de contexto inyectado al system_prompt al arrancar.
JARVIS_SESSION_RECALL_MAX_CHARS=1000
# Cuantas sesiones recientes se inyectan como mapa temporal al arrancar.
JARVIS_SESSION_RECENT_LIMIT=5

# --- Fase 3: Proactividad y Agencia (KAG) ---
# Master switch de todo el motor de proactividad (briefing + deteccion + tool).
JARVIS_PROACTIVITY_ENABLED=true
# Dias para considerar "stale" un pendiente abierto de una card.
JARVIS_PROACTIVITY_STALE_PENDING_DAYS=7
# Dias para considerar "stale" un proyecto importante sin tocar.
JARVIS_PROACTIVITY_STALE_PROJECT_DAYS=14
# Tope de sugerencias ofrecidas por sesion (anti-spam).
JARVIS_PROACTIVITY_MAX_PER_SESSION=3
# No repetir una sugerencia descartada en N dias.
JARVIS_PROACTIVITY_COOLDOWN_DAYS=7
# Cuantas oportunidades entran en el briefing de arranque.
JARVIS_PROACTIVITY_BRIEFING_TOP_K=3
# Score minimo para considerar una oportunidad.
JARVIS_PROACTIVITY_MIN_SCORE=0.35

# === Camara / Vision ===
# Indice del dispositivo de camara. auto prueba 0..JARVIS_CAMERA_SCAN_MAX-1.
JARVIS_CAMERA_INDEX=auto
# Backends OpenCV a probar en Windows: auto = dshow,msmf,any.
JARVIS_CAMERA_BACKEND=auto
JARVIS_CAMERA_SCAN_MAX=6
# Lado maximo del frame enviado (px); se reescala manteniendo aspecto.
JARVIS_CAMERA_MAX_SIDE=1280
# Horas de retencion de los frames en data/camera (0 = borrar tras enviar).
JARVIS_CAMERA_RETENTION_HOURS=24
# FPS del modo vision continuo (camera_watch).
JARVIS_CAMERA_FPS=3.0
# Duracion por defecto del modo vision (segundos) y tope duro de seguridad.
JARVIS_CAMERA_WATCH_DEFAULT_S=90
JARVIS_CAMERA_WATCH_MAX_S=180
# Preview en vivo de lo que ve JARVIS (1=on, 0=off) y tamano de la ventana (px).
JARVIS_CAMERA_PREVIEW=1
JARVIS_CAMERA_PREVIEW_SIZE=480
# Modelo (no-Live) para la deteccion one-shot del crosshair (camera_focus).
JARVIS_CAMERA_DETECT_MODEL=gemini-3.1-flash
